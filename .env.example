# ============================================================
# Conteo — variables de entorno (copiar a .env y completar)
# ============================================================

# --- App ---
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=conteo
POSTGRES_PASSWORD=conteo
POSTGRES_DB=conteo
DATABASE_URL=postgresql://conteo:conteo@localhost:5432/conteo?schema=public

# --- Redis (BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Object Storage (MinIO / S3 / R2) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_EVIDENCE=conteo-evidence
S3_FORCE_PATH_STYLE=true

# --- OCR (elegir un proveedor; vacío = modo stub) ---
OCR_PROVIDER=stub          # stub | gcp-documentai | aws-textract | azure-di
# GCP_DOCUMENTAI_PROJECT_ID=
# GCP_DOCUMENTAI_LOCATION=us
# GCP_DOCUMENTAI_PROCESSOR_ID=
# AWS_REGION=us-east-1
# AZURE_DI_ENDPOINT=
# AZURE_DI_KEY=

# --- Analytics (Python service) ---
ANALYTICS_URL=http://localhost:8001

# --- Crawler oficial (límites de cortesía) ---
CRAWLER_USER_AGENT=ConteoAuditBot/0.1 (+contacto@ejemplo.org)
CRAWLER_MAX_RPS=1            # peticiones por segundo (cortesía)
CRAWLER_CONCURRENCY=2

# --- Versionado para auditoría ---
RULES_VERSION=2026.06.0

# --- Anthropic Claude API --- (NO usar para OCR masivo - muy costoso)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXX

# --- Google Gemini Flash (OCR de actas - mucho más barato) ---
# Obtener key GRATIS en: https://aistudio.google.com/app/apikey
# Tier gratuito: 15 req/min, 1M tokens/día — suficiente para ~500 actas/día sin costo
# Tier pago: ~$0.075/1M tokens de entrada ≈ $9-18 para las 121k actas completas
GOOGLE_API_KEY=

# --- Autenticación ---
JWT_SECRET=cambia-esto-en-produccion
